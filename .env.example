# Получить у @BotFather в Telegram
BOT_TOKEN=your_bot_token_here

# Ключ Anthropic API — https://console.anthropic.com/
ANTHROPIC_KEY=sk-ant-...

# Публичный URL вашего сервера (для webhook Telegram)
# На Render.com выглядит так: https://maria-bot.onrender.com
WEBHOOK_URL=https://your-app.onrender.com

# URL Mini App — обычно совпадает с WEBHOOK_URL
MINI_APP_URL=https://your-app.onrender.com

# Порт (Render подставляет автоматически)
PORT=3000
